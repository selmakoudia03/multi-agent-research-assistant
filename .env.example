# LLM provider: "mock" (offline, default, used in tests/CI) | "anthropic" | "openai"
MAGENT_LLM_PROVIDER=mock

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Reflection loop cap and tool sandbox timeout (seconds)
MAGENT_MAX_ITERATIONS=3
MAGENT_TOOL_TIMEOUT=5
